# Copy to .env and fill in the keys for the providers you want to call.
# Leave a key blank to skip that provider (cached responses still work offline).

# OpenRouter: ONE key for many models (gpt, claude, llama, qwen, ...).
# Get it at https://openrouter.ai/keys . Recommended for this demo.
OPENROUTER_API_KEY=

# Direct provider keys (optional, only if you use provider: openai / anthropic).
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
