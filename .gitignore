.venv/
__pycache__/
*.pyc
.env
.claude/settings.local.json

# Generated tables/figures are regenerated from per_item.csv on every run.
data/*.jsonl
results/*.csv
results/figures/*.png
!**/.gitkeep

# Prediction cache IS committed: greedy generations keyed by sha256(model_id,
# prompt). Re-running on Kaggle hits the cache for already-scored models, so only
# new models actually call the GPU. This is the reproducibility mechanism.
!results/predictions/
!results/predictions/*.json

# LaTeX build artifacts (top-level and latexmk -outdir=output/)
report/output/
report/*.aux
report/*.log
report/*.out
report/*.fls
report/*.fdb_latexmk
report/*.bbl
report/*.blg
report/*.xdv
report/*.synctex.gz
report/main.pdf

# personal task-assignment file, never commit
phan_cong_lab3.md
