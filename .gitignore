.venv/
__pycache__/
*.pyc
.env
.claude/settings.local.json

# Generated tables/figures are regenerated from per_item.csv on every run.
data/*.jsonl
results/*.csv
results/figures/*.png
!**/.gitkeep

# Prediction cache IS committed: greedy generations keyed by sha256(model_id,
# prompt). Re-running on Kaggle hits the cache for already-scored models, so only
# new models actually call the GPU. This is the reproducibility mechanism.
!results/predictions/
!results/predictions/*.json
